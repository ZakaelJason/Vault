<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris atas: nama item + badge status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOrderItemName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/status_badge_bg"/>
        </LinearLayout>

        <!-- Role: buyer / seller info -->
        <TextView
            android:id="@+id/tvOrderRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="6dp"/>

        <!-- Baris tombol: Action + Chat + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <!-- Upload/View Proof -->
            <Button
                android:id="@+id/btnAction"
                style="@style/VaultButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:textSize="13sp"
                android:visibility="gone"/>

            <!-- Chat dengan penjual/pembeli — BARU -->
            <Button
                android:id="@+id/btnChat"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text="💬"
                android:textSize="18sp"
                android:visibility="visible"/>

            <!-- Hapus transaksi -->
            <Button
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Delete"
                android:textColor="#EF5350"
                android:textSize="13sp"
                android:layout_marginStart="4dp"
                android:visibility="visible"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>